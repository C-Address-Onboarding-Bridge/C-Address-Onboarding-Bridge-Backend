{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "alertlist", "name": "Alert list", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "C-Address Bridge – Active Alerts & SLO Burn Rate",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": ["alertname", "severity"],
        "groupMode": "custom",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": { "error": true, "firing": true, "noData": false, "normal": false, "pending": true },
        "viewMode": "list"
      },
      "title": "Active Alerts",
      "type": "alertlist"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(ALERTS{alertstate=\"firing\", severity=\"critical\", job=\"c-address-bridge\"})",
          "legendFormat": "Critical"
        }
      ],
      "title": "Critical Alerts Firing",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "orange", "value": 3 }] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(ALERTS{alertstate=\"firing\", severity=\"warning\", job=\"c-address-bridge\"})",
          "legendFormat": "Warning"
        }
      ],
      "title": "Warning Alerts Firing",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(ALERTS{alertstate=\"pending\", job=\"c-address-bridge\"})",
          "legendFormat": "Pending"
        }
      ],
      "title": "Pending Alerts",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.02 }, { "color": "red", "value": 0.1 }] } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 5,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "1 - (sum(rate(http_requests_total{job=\"c-address-bridge\",status!~\"5..\"}[1h])) / sum(rate(http_requests_total{job=\"c-address-bridge\"}[1h])))",
          "legendFormat": "1h Error Burn Rate"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "1 - (sum(rate(http_requests_total{job=\"c-address-bridge\",status!~\"5..\"}[6h])) / sum(rate(http_requests_total{job=\"c-address-bridge\"}[6h])))",
          "legendFormat": "6h Error Burn Rate"
        }
      ],
      "title": "SLO Error Burn Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 6,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "changes(ALERTS{alertstate=\"firing\", job=\"c-address-bridge\"}[24h])",
          "legendFormat": "{{alertname}}"
        }
      ],
      "title": "Alert History (24h changes)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 7,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "1 - (sum_over_time(bridge_slo_availability[30d]) / (30 * 24 * 3600))",
          "legendFormat": "30d SLO Burn"
        }
      ],
      "title": "30-day SLO Burn Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["c-address-bridge", "alerts", "slo"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "C-Address Bridge – Alerts & SLO",
  "uid": "cab-alerts-slo",
  "version": 1
}
